{
  "name": "@patchproof/github-action",
  "version": "0.1.0",
  "description": "PatchProof GitHub Action wrapper.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@patchproof/adapters-node": "workspace:*",
    "@patchproof/adapters-python": "workspace:*",
    "@patchproof/config": "workspace:*",
    "@patchproof/core": "workspace:*"
  }
}
